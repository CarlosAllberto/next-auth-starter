generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id                   Int    @id @default(autoincrement())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  provider             String?
  role                 String?
  password             String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

